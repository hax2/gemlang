  "vocabulary": {
    "mariposa": {
      "mnemonic": "'Mary poses' — a butterfly posing!",
      "explanation": "Means 'butterfly'."
    },
    "aire": {
      "mnemonic": "Same as English 'air'!",
      "explanation": "Cognate."
    },
    "eres": {
      "mnemonic": "Sounds like 'air is' — 'You are like air.'",
      "explanation": "Informal 'you are' form of 'ser'."
    },
    "y": {
      "mnemonic": "The letter 'Y' connects — like 'and' connects words.",
      "explanation": "Pronounced like 'ee'. The simplest conjunction."
    },
    "verde": {
      "mnemonic": "Think 'verdant' — lush green vegetation.",
      "explanation": "Means 'green'. Same for masc/fem."
    },
    "luz": {
      "mnemonic": "Think 'lux/luminous' — light.",
      "explanation": "Feminine noun."
    },
    "estás": {
      "mnemonic": "Think 'you establish your position'.",
