  "grammarExplanation": "Regular -AR verbs follow a predictable conjugation pattern. Remove '-ar' and add these endings:\n\n• -o (yo): hablo\n• -as (tú): hablas\n• -a (él/ella): habla\n• -amos (nosotros): hablamos\n• -an (ustedes/ellos): hablan\n\nThis same pattern works for hablar, trabajar, estudiar, comprar, buscar, esperar, escuchar, mirar, and many more.",
  "vocabulary": {
    "hablo": {
      "mnemonic": "Think 'hobble along while speaking'.",
      "explanation": "First person of 'hablar' (to speak)."
    },
    "español": {
      "mnemonic": "'Espagne/Spain' + '-ol' — the Spanish language.",
      "explanation": "Both the language and nationality."
    },
    "hablas": {
      "mnemonic": "'Ha-blas' — you blast out words.",
      "explanation": "Second person of 'hablar'."
    },
    "él": {
      "mnemonic": "Like 'el' in 'elevator' — he goes up!",
      "explanation": "Subject pronoun 'he'. Accent distinguishes from 'el' (the)."
    },
    "habla": {
      "mnemonic": "'Ha-bla' — he/she speaks.",
      "explanation": "Third person of 'hablar'."
    },
    "ella": {
      "mnemonic": "Think 'Cinderella' ends with '-ella' — she!",
      "explanation": "Subject pronoun 'she/her'."
    },
    "nosotros": {
