  "grammarExplanation": "Use Present Perfect (he comido) for actions that happened in a time period that isn't finished yet (hoy, esta semana, este año) or for life experiences (alguna vez, nunca). Use Preterite (comí) for actions in a completely finished time period (ayer, la semana pasada, en 2018). *Note: In Latin America, the Preterite is often used for both cases.*",
  "vocabulary": {
    "hoy": {
      "mnemonic": "Hoy is the present day.",
      "explanation": "Means 'today'."
    },
    "comido": {
      "mnemonic": "Past participle of comer.",
      "explanation": "Means 'eaten'."
    },
    "pronto": {
      "mnemonic": "Do it pronto!",
      "explanation": "Means 'soon' or 'early'."
    },
    "semana": {
      "mnemonic": "See men a week.",
      "explanation": "Means 'week'."
    },
    "trabajado": {
      "mnemonic": "Past participle of trabajar.",
      "explanation": "Means 'worked'."
    },
    "pasada": {
      "mnemonic": "Passed by.",
      "explanation": "Means 'past' or 'last' (as in last week)."
    },
    "alguna": {
      "mnemonic": "Alternative or some one.",
      "explanation": "Means 'some'."
    },
    "vez": {
      "mnemonic": "This time interval.",
      "explanation": "Means 'time' as an instance (e.g. one time)."
    },
    "estado": {
      "mnemonic": "State of being.",
      "explanation": "Past participle of estar (been)."
    },
    "año": {
      "mnemonic": "Annual.",
      "explanation": "Means 'year'."
    },
    "nunca": {
      "mnemonic": "None can.",
      "explanation": "Means 'never'."
    },
    "probado": {
      "mnemonic": "Probation tests you.",
      "explanation": "Past participle of probar (tried/tasted)."
    },
    "ya": {
      "mnemonic": "Yeah, already done.",
      "explanation": "Means 'already' or 'now'."
    },
    "llegado": {
      "mnemonic": "Leg arrived.",
      "explanation": "Past participle of llegar (arrived)."
    },
    "hace": {
      "mnemonic": "Hace frio means it makes cold.",
      "explanation": "Used in time expressions to mean 'ago' (Hace diez minutos)."
    },
    "siempre": {
      "mnemonic": "Semper fi - always faithful.",
      "explanation": "Means 'always'."
    },
    "gustado": {
      "mnemonic": "Gusto is pleasure.",
      "explanation": "Past participle of gustar (liked/pleased)."
    },
    "ciudad": {
