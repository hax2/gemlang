  "grammarExplanation": "Real (open) conditionals describe things that CAN or DO happen when a condition is met. The 'si' clause uses the PRESENT INDICATIVE:\n\n'Si + present tense, present tense / command'\n\n• Si tienes tiempo, te vienes = If you have time, come along.\n• Si estudias, aprendes = If you study, you learn.\n• Si llueve, me quedo en casa = If it rains, I stay home.\n\nThe 'si' clause can go first or second: 'Te vienes si tienes tiempo.'",
  "vocabulary": {
    "si": {
      "mnemonic": "'See if' — si = if.",
      "explanation": "No accent = if. 'Sí' with accent = yes."
    },
    "tienes": {
      "mnemonic": "'Tea-en-es' — you have tea.",
      "explanation": "Informal 'you have'. From 'tener'."
    },
    "tiempo": {
      "mnemonic": "Think 'tempo' — time and rhythm.",
      "explanation": "Means 'time' or 'weather'."
    },
    "dinero": {
      "mnemonic": "'Diner-o' — you need dinero at the diner.",
      "explanation": "Means 'money'."
    },
    "compras": {
      "mnemonic": "'Compare and purchase' — you buy.",
      "explanation": "Second person of 'comprar'."
    },
    "pan": {
      "mnemonic": "Bread baked in a pan!",
      "explanation": "Means 'bread'. Masculine noun."
    },
    "estudias": {
      "mnemonic": "'You study-as' — you study.",
      "explanation": "Second person of 'estudiar'."
    },
    "trabajas": {
      "mnemonic": "'Travel-has' — you work.",
      "explanation": "Second person of 'trabajar'."
    },
    "mucho": {
      "mnemonic": "Think 'much-o' — much/a lot!",
      "explanation": "Means 'much/a lot'. Fem: mucha."
    },
    "comes": {
      "mnemonic": "'Comes to eat' — you eat.",
      "explanation": "Second person of 'comer'."
    },
    "bebes": {
      "mnemonic": "Think 'babies drink'.",
      "explanation": "Second person of 'beber'."
    },
    "agua": {
      "mnemonic": "Think 'aqua' — water!",
      "explanation": "Fem but uses 'el agua'."
    },
    "estás": {
      "mnemonic": "Think 'you establish your position'.",
      "explanation": "Informal 'you are' (estar)."
    },
    "mejor": {
      "mnemonic": "'Major improvement' — better/best.",
      "explanation": "Means 'better' or 'best'."
    },
    "temprano": {
      "mnemonic": "'Temporary morning' — early!",
      "explanation": "Means 'early'."
    },
    "hablamos": {
      "mnemonic": "'Hobble-amos' — we talk.",
      "explanation": "First person plural of 'hablar'."
    },
    "tarde": {
      "mnemonic": "Think 'tardy' — late!",
      "explanation": "Means 'late' or 'afternoon'."
    },
    "comemos": {
      "mnemonic": "'Come-emos' — we eat together.",
      "explanation": "First person plural of 'comer'."
    },
    "mañana": {
      "mnemonic": "'Mañana, mañana' — putting off till tomorrow.",
      "explanation": "Means 'tomorrow' or 'morning'."
    },
    "vamos": {
      "mnemonic": "'¡Vamos!' — Let's go! Already English.",
      "explanation": "First person plural of 'ir'."
    },
    "café": {
      "mnemonic": "Same as English 'café' — coffee!",
      "explanation": "Means 'coffee' or 'café'."
    },
    "vas": {
      "mnemonic": "'Vast journey' — you go.",
      "explanation": "Second person of 'ir'."
    },
    "hoy": {
      "mnemonic": "'Hoy! today!' — an exclamation for today.",
      "explanation": "Means 'today'."
    },
    "libro": {
      "mnemonic": "Think 'library' — full of libros (books)!",
      "explanation": "Means 'book'. Masculine noun."
    },
    "la": {
      "mnemonic": "'La lady' — her/it (feminine).",
      "explanation": "Also 'the' (feminine)."
    },
    "puerta": {
